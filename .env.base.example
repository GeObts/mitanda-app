# ─────────────────────────────────────────────────────────────────────────────
# Base App build configuration. Copy to `.env.base` and fill in.
#   cp .env.base.example .env.base
# Used by scripts/deploy-base.mjs (npm run cf:build:base / cf:deploy:base).
# Everything here is PUBLIC (inlined into the client bundle) — no secrets.
# Server secrets go to `wrangler secret put … -c wrangler.base.jsonc` instead.
# ─────────────────────────────────────────────────────────────────────────────

# Repoints the whole app to Base mainnet. (deploy-base.mjs forces this too.)
NEXT_PUBLIC_ACTIVE_CHAIN=base

# The public URL the Base App build is served at — used for embed/OG metadata
# and the Farcaster manifest. No trailing slash. This is the URL you register
# on base.dev as the app's Primary URL.
NEXT_PUBLIC_APP_URL=https://base.mitanda.online

# Privy App ID (login is NOT used in the Base App build, but harmless to keep).
NEXT_PUBLIC_PRIVY_APP_ID=cmpoddngc004e0bjutoaor7t4

# ── Base mainnet contract addresses (REQUIRED) ───────────────────────────────
# From mitanda-contracts/deployments/base-mainnet.md. The Base App build is
# non-functional until these five are set (USDC has a correct default).
NEXT_PUBLIC_BASE_MANAGER_ADDRESS=
NEXT_PUBLIC_BASE_TANDA_IMPL_ADDRESS=
NEXT_PUBLIC_BASE_PASS_NFT_ADDRESS=
NEXT_PUBLIC_BASE_RECEIPT_NFT_ADDRESS=
NEXT_PUBLIC_BASE_COMPLETION_NFT_ADDRESS=
# Circle USDC on Base mainnet — already defaulted in code; override only if needed.
# NEXT_PUBLIC_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Builder Code attribution (recommended, for Base Rewards) ──────────────────
# Precomputed ERC-8021 calldata suffix for your base.dev Builder Code. See
# docs/BASE_APP.md → "Builder Code" for how to generate this. Safe to leave blank.
NEXT_PUBLIC_BUILDER_DATA_SUFFIX=

# ── Optional RPC override (a dedicated endpoint handles multicall load better) ─
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
