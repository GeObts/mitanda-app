# Mi Tanda app — environment template. Copy to .env.local and fill in.
# Most vars are NEXT_PUBLIC_* (client-side config). The Etherfuse key below is a
# SERVER-SIDE SECRET (no NEXT_PUBLIC_ prefix) — never expose it to the browser.

# Privy auth — required for wallet login. Get an App ID at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=<your-privy-app-id>

# RPC endpoints (optional overrides — sensible public defaults are built in).
# Use your own (e.g. Alchemy) for reliability under load.
# Active chain is Arbitrum One (mainnet) — strongly recommend a dedicated RPC here.
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contract address overrides (OPTIONAL). The live addresses are hardcoded in
# lib/contracts/addresses.ts; set these only to point elsewhere.
# Active = Arbitrum One (mainnet):
# NEXT_PUBLIC_ARB_ONE_MANAGER_ADDRESS=
# NEXT_PUBLIC_ARB_ONE_TANDA_IMPL_ADDRESS=
# NEXT_PUBLIC_ARB_ONE_PASS_NFT_ADDRESS=
# NEXT_PUBLIC_ARB_ONE_RECEIPT_NFT_ADDRESS=
# NEXT_PUBLIC_ARB_ONE_COMPLETION_NFT_ADDRESS=
# Testnet (Arbitrum Sepolia):
# NEXT_PUBLIC_ARB_MANAGER_ADDRESS=

# ── Etherfuse (CETES yield + USDC→CETES swap) ────────────────────────────────
# SERVER-SIDE SECRET — used only by app/api/etherfuse/* route handlers. The org
# /customer id is derived from the key at runtime (key.split(":")[2]); do NOT
# hardcode it. Get a sandbox key at https://devnet.etherfuse.com
ETHERFUSE_SANDBOX_API_KEY=<your-etherfuse-sandbox-key>
ETHERFUSE_SANDBOX_BASE_URL=https://api.sand.etherfuse.com
# Solana RPC for the wallet-adapter swap demo (optional — defaults to devnet).
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
